# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
# Used by docker-compose to set the initial DB credentials (user/password)
NEO4J_AUTH=neo4j/password123

# Anthropic (LLM extraction + text2cypher)
ANTHROPIC_API_KEY=sk-ant-...
KGRF_LLM_MODEL=claude-opus-4-8

# Reasoning weights (tunable — the logic lives here, not in a model)
KGRF_WEIGHT_DIRECT=1.0
KGRF_WEIGHT_INFERRED=0.8
KGRF_WEIGHT_ADJACENT=0.4
KGRF_ADJACENT_MAX_HOPS=2
